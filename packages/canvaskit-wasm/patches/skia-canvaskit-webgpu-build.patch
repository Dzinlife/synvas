+std::tuple<skgpu::graphite::BackendTexture, SkImages::GraphitePromiseTextureReleaseContext>
+FulfillWebGPUTexturePromise(SkImages::GraphitePromiseTextureFulfillContext fulfillContext) {
+    auto* context = reinterpret_cast<WebGPUTexturePromiseImageContext*>(fulfillContext);
+    if (!context) {
+        return {{}, nullptr};
+    }
+
+    const auto textureHandle = context->fCallback.call<uint32_t>("makeTexture");
+    if (!textureHandle) {
+        return {{}, nullptr};
+    }
+
+    WGPUTexture rawTexture = canvaskit_import_webgpu_texture(textureHandle);
+    if (!rawTexture) {
+        context->fCallback.call<void>("releaseTexture", textureHandle);
+        return {{}, nullptr};
+    }
+
+    auto target = skgpu::graphite::BackendTextures::MakeDawn(
+            {context->fWidth, context->fHeight},
+            skgpu::graphite::DawnTextureInfo(
+                    skgpu::graphite::SampleCount::k1,
+                    skgpu::Mipmapped::kNo,
+                    static_cast<wgpu::TextureFormat>(context->fTextureFormat),
+                    static_cast<wgpu::TextureUsage>(context->fTextureUsage),
+                    wgpu::TextureAspect::All),
+            rawTexture);
+    if (!target.isValid()) {
+        context->fCallback.call<void>("releaseTexture", textureHandle);
+        return {{}, nullptr};
+    }
+
+    auto* releaseContext = new WebGPUTexturePromiseReleaseContext{
+            context->fCallback,
+            textureHandle,
+    };
+    return {target, reinterpret_cast<SkImages::GraphitePromiseTextureReleaseContext>(
+                            releaseContext)};
+}
