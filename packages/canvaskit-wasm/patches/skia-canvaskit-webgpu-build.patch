SkColorType ResolveWebGPUTextureColorType(wgpu::TextureFormat textureFormat) {
    switch (textureFormat) {
        case wgpu::TextureFormat::BGRA8Unorm:
        case wgpu::TextureFormat::BGRA8UnormSrgb:
            return SkColorType::kBGRA_8888_SkColorType;
        case wgpu::TextureFormat::RGBA8Unorm:
        case wgpu::TextureFormat::RGBA8UnormSrgb:
        default:
            return SkColorType::kRGBA_8888_SkColorType;
    }
}

sk_sp<SkImage> MakeGPUTextureImage(WebGPUDeviceContext& dContext,
                                   uint32_t textureHandle,
                                   uint32_t textureFormat,
                                   uint32_t textureUsage,
                                   int width,
                                   int height,
                                   sk_sp<SkColorSpace> colorSpace,
                                   bool srcIsPremul) {
    if (!colorSpace) {
        colorSpace = SkColorSpace::MakeSRGB();
    }

    WGPUTexture rawTexture = emscripten_webgpu_import_texture(textureHandle);
    emscripten_webgpu_release_js_handle(textureHandle);
    if (!rawTexture) {
        return nullptr;
    }

    const auto dawnTextureFormat = static_cast<wgpu::TextureFormat>(textureFormat);
    auto target = skgpu::graphite::BackendTextures::MakeDawn(
            {width, height},
            skgpu::graphite::DawnTextureInfo(
                    skgpu::graphite::SampleCount::k1,
                    skgpu::Mipmapped::kNo,
                    dawnTextureFormat,
                    static_cast<wgpu::TextureUsage>(textureUsage),
                    wgpu::TextureAspect::All),
            rawTexture);
    if (!target.isValid()) {
        return nullptr;
    }

    return SkImages::WrapTexture(
            dContext.recorder(),
            target,
            ResolveWebGPUTextureColorType(dawnTextureFormat),
            srcIsPremul ? SkAlphaType::kPremul_SkAlphaType
                        : SkAlphaType::kUnpremul_SkAlphaType,
            colorSpace);
}

