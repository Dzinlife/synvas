+class WebGPUImageProvider final : public skgpu::graphite::ImageProvider {
+public:
+    static sk_sp<WebGPUImageProvider> Make() { return sk_sp(new WebGPUImageProvider); }
+
+    sk_sp<SkImage> findOrCreate(skgpu::graphite::Recorder* recorder,
+                                const SkImage* image,
+                                SkImage::RequiredProperties requiredProps) override {
+        const uint64_t cacheKey = MakeCacheKey(image, requiredProps);
+        auto found = fCache.find(cacheKey);
+        if (found != fCache.end()) {
+            return found->second;
+        }
+
+        sk_sp<SkImage> graphiteImage = SkImages::TextureFromImage(recorder, image, requiredProps);
+        if (graphiteImage) {
+            fCache.emplace(cacheKey, graphiteImage);
+        }
+        return graphiteImage;
+    }
+
+private:
+    WebGPUImageProvider() = default;
+
+    static uint64_t MakeCacheKey(const SkImage* image,
+                                 SkImage::RequiredProperties requiredProps) {
+        return (static_cast<uint64_t>(image->uniqueID()) << 1) |
+               (requiredProps.fMipmapped ? 1ull : 0ull);
+    }
+
+    std::unordered_map<uint64_t, sk_sp<SkImage>> fCache;
+};
+
+class WebGPUDeviceContext {
+public:
+    WebGPUDeviceContext(std::unique_ptr<skgpu::graphite::Context> context,
+                        std::unique_ptr<skgpu::graphite::Recorder> recorder)
+            : fContext(std::move(context))
+            , fRecorder(std::move(recorder)) {}
+
+    bool submit() {
+        if (!fContext || !fRecorder) {
+            return false;
+        }
+
+        std::unique_ptr<skgpu::graphite::Recording> recording = fRecorder->snap();
+        if (!recording) {
+            return false;
+        }
+
+        skgpu::graphite::InsertRecordingInfo info;
+        info.fRecording = recording.get();
+        if (fContext->insertRecording(info) != skgpu::graphite::InsertStatus::kSuccess) {
+            return false;
+        }
+
+        return fContext->submit();
+    }
+
+    skgpu::graphite::Recorder* recorder() const { return fRecorder.get(); }
+
+private:
+    std::unique_ptr<skgpu::graphite::Context> fContext;
+    std::unique_ptr<skgpu::graphite::Recorder> fRecorder;
+};
