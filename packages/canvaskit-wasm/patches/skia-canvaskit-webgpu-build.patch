+JSObject SkImagesMakeWithFilter(WebGPUDeviceContext& dContext,
+                                sk_sp<SkImage> src,
+                                const SkImageFilter* filter,
+                                SimpleIRect subset,
+                                SimpleIRect clipBounds) {
+    if (!src || !filter) {
+        return emscripten::val::null();
+    }
+
+    SkIRect outSubset;
+    SkIPoint offset;
+    auto image = SkImages::MakeWithFilter(dContext.recorder(),
+                                          std::move(src),
+                                          filter,
+                                          toSkIRect(subset),
+                                          toSkIRect(clipBounds),
+                                          &outSubset,
+                                          &offset);
+    if (!image) {
+        return emscripten::val::null();
+    }
+
+    JSObject result = emscripten::val::object();
+    JSObject subsetValue = emscripten::val::object();
+    subsetValue.set("left", outSubset.left());
+    subsetValue.set("top", outSubset.top());
+    subsetValue.set("right", outSubset.right());
+    subsetValue.set("bottom", outSubset.bottom());
+    JSObject offsetValue = emscripten::val::object();
+    offsetValue.set("x", offset.x());
+    offsetValue.set("y", offset.y());
+    result.set("image", image);
+    result.set("outSubset", subsetValue);
+    result.set("offset", offsetValue);
+    return result;
 }
 
