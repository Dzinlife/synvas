+class WebGPUImageProvider final : public skgpu::graphite::ImageProvider {
+public:
+    static sk_sp<WebGPUImageProvider> Make() { return sk_sp(new WebGPUImageProvider); }
+
+    sk_sp<SkImage> findOrCreate(skgpu::graphite::Recorder* recorder,
+                                const SkImage* image,
+                                SkImage::RequiredProperties requiredProps) override {
+        const uint64_t cacheKey = MakeCacheKey(image, requiredProps);
+        auto found = fCache.find(cacheKey);
+        if (found != fCache.end()) {
+            return found->second;
+        }
+
+        sk_sp<SkImage> graphiteImage = SkImages::TextureFromImage(recorder, image, requiredProps);
+        if (graphiteImage) {
+            fCache.emplace(cacheKey, graphiteImage);
+        }
+        return graphiteImage;
+    }
+
+private:
+    WebGPUImageProvider() = default;
+
+    static uint64_t MakeCacheKey(const SkImage* image,
+                                 SkImage::RequiredProperties requiredProps) {
+        return (static_cast<uint64_t>(image->uniqueID()) << 1) |
+               (requiredProps.fMipmapped ? 1ull : 0ull);
+    }
+
+    std::unordered_map<uint64_t, sk_sp<SkImage>> fCache;
