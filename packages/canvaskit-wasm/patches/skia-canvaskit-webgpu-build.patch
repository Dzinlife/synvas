+struct AsyncReadContext {
+    JSObject fCallback;
+    std::vector<size_t> fPlaneHeights;
+    int fWidth = 0;
+    int fHeight = 0;
+};
+
+JSObject MakeAsyncReadResultValue(const SkImage::AsyncReadResult& result,
+                                  const AsyncReadContext& context) {
+    JSObject jsResult = emscripten::val::object();
+    JSObject planes = emscripten::val::array();
+    JSObject rowBytes = emscripten::val::array();
+    for (int planeIndex = 0; planeIndex < result.count(); ++planeIndex) {
+        const size_t planeHeight = planeIndex < static_cast<int>(context.fPlaneHeights.size())
+                                           ? context.fPlaneHeights[planeIndex]
+                                           : 0;
+        const size_t planeRowBytes = result.rowBytes(planeIndex);
+        const size_t planeSize = planeHeight * planeRowBytes;
+        planes.set(
+                planeIndex,
+                emscripten::val(typed_memory_view(
+                                        planeSize,
+                                        reinterpret_cast<const uint8_t*>(result.data(planeIndex))))
+                        .call<Uint8Array>("slice"));
+        rowBytes.set(planeIndex, static_cast<unsigned int>(planeRowBytes));
+    }
+    jsResult.set("planes", planes);
+    jsResult.set("rowBytes", rowBytes);
+    jsResult.set("count", result.count());
+    jsResult.set("width", context.fWidth);
+    jsResult.set("height", context.fHeight);
+    return jsResult;
+}
+
+void ResolveAsyncReadCallback(SkImage::ReadPixelsContext readContext,
+                              std::unique_ptr<const SkImage::AsyncReadResult> result) {
+    std::unique_ptr<AsyncReadContext> context(reinterpret_cast<AsyncReadContext*>(readContext));
+    if (!context) {
+        return;
+    }
+
+    if (!result) {
+        context->fCallback.call<void>("resolve", emscripten::val::null());
+        return;
+    }
+    context->fCallback.call<void>("resolve", MakeAsyncReadResultValue(*result, *context));
+}
