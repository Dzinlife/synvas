+sk_sp<SkImage> SkImagesPromiseTextureFrom(WebGPUDeviceContext& dContext,
+                                          uint32_t textureFormat,
+                                          uint32_t textureUsage,
+                                          int width,
+                                          int height,
+                                          SimpleColorInfo colorInfo,
+                                          skgpu::Origin origin,
+                                          bool isVolatile,
+                                          JSObject callbackObj,
+                                          std::string label) {
+    const auto dawnTextureFormat = static_cast<wgpu::TextureFormat>(textureFormat);
+    const auto textureInfo = skgpu::graphite::TextureInfos::MakeDawn(
+            skgpu::graphite::DawnTextureInfo(skgpu::graphite::SampleCount::k1,
+                                             skgpu::Mipmapped::kNo,
+                                             dawnTextureFormat,
+                                             static_cast<wgpu::TextureUsage>(textureUsage),
+                                             wgpu::TextureAspect::All));
+
+    auto* imageContext = new WebGPUTexturePromiseImageContext{
+            callbackObj,
+            width,
+            height,
+            textureFormat,
+            textureUsage,
+    };
+
+    auto image = SkImages::PromiseTextureFrom(
+            dContext.recorder(),
+            {width, height},
+            textureInfo,
+            toSkColorInfo(colorInfo),
+            origin,
+            isVolatile ? skgpu::graphite::Volatile::kYes : skgpu::graphite::Volatile::kNo,
+            FulfillWebGPUTexturePromise,
+            ReleaseWebGPUTexturePromiseImage,
+            ReleaseWebGPUTexturePromiseTexture,
+            reinterpret_cast<SkImages::GraphitePromiseImageContext>(imageContext),
+            label);
+    if (!image) {
+        ReleaseWebGPUTexturePromiseImage(
+                reinterpret_cast<SkImages::GraphitePromiseImageContext>(imageContext));
+        return nullptr;
+    }
+    return image;
+}
