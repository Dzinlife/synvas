+std::tuple<skgpu::graphite::BackendTexture, SkImages::GraphitePromiseTextureReleaseContext>
+FulfillWebGPUTexturePromise(SkImages::GraphitePromiseTextureFulfillContext fulfillContext) {
+    auto* context = reinterpret_cast<WebGPUTexturePromiseImageContext*>(fulfillContext);
+    if (!context) {
+        return {{}, nullptr};
+    }
+
+    const auto textureHandle = context->fCallback.call<uint32_t>("makeTexture");
+    if (!textureHandle) {
+        return {{}, nullptr};
+    }
+
+    auto backendTexture = MakeWebGPUBackendTexture(textureHandle,
+                                                   context->fTextureFormat,
+                                                   context->fTextureUsage,
+                                                   context->fWidth,
+                                                   context->fHeight);
+    if (!backendTexture.isValid()) {
+        context->fCallback.call<void>("releaseTexture", textureHandle);
+        return {{}, nullptr};
+    }
+
+    auto* releaseContext =
+            new WebGPUTexturePromiseReleaseContext{context->fCallback, textureHandle};
+    return {backendTexture,
+            reinterpret_cast<SkImages::GraphitePromiseTextureReleaseContext>(releaseContext)};
+}
